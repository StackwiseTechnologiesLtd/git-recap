#!/usr/bin/env bash
# git-recap — aggregate your local commit messages for standups.
# Pure Bash + git; works entirely offline from local .git state.
# Compatible with Bash 3.2+ (macOS).

set -euo pipefail

# ---------------------------------------------------------------------------
# Defaults / configuration
# ---------------------------------------------------------------------------
VERSION="0.1.2"
SINCE="${GIT_RECAP_SINCE:-1 day ago}"
UNTIL="${GIT_RECAP_UNTIL:-}"
MAX_SUBJECT_LENGTH="${GIT_RECAP_MAX_SUBJECT_LENGTH:-88}"
FLAT=0
PLAIN=0
SUMMARY_ONLY=0
RECURSIVE=0
JSON=0
ALL_AUTHORS=0
INCLUDE_MERGES=0
INCLUDE_REVIEWS=0
# auto | always | never — NO_COLOR forces never unless --color=always
COLOR_MODE="${GIT_RECAP_COLOR:-auto}"
AUTHOR_OVERRIDE="${GIT_RECAP_AUTHOR:-}"
TARGETS=()
CATEGORIES=(Features Fixes Docs Refactors Tests Performance Chores Reviews Other)

# Global summary state. Kept as scalar variables for macOS Bash 3.x support.
TOTAL_COMMITS=0
TOTAL_REVIEWS=0
PRINTED_REPOS=0
G_FEATURES_COUNT=0; G_FIXES_COUNT=0; G_DOCS_COUNT=0; G_REFACTORS_COUNT=0
G_TESTS_COUNT=0; G_PERFORMANCE_COUNT=0; G_CHORES_COUNT=0; G_REVIEWS_COUNT=0; G_OTHER_COUNT=0
G_FEATURES_ITEMS=''; G_FIXES_ITEMS=''; G_DOCS_ITEMS=''; G_REFACTORS_ITEMS=''
G_TESTS_ITEMS=''; G_PERFORMANCE_ITEMS=''; G_CHORES_ITEMS=''; G_REVIEWS_ITEMS=''; G_OTHER_ITEMS=''

usage() {
  # Disable line wrapping (\033[?7l) so the ASCII art doesn't scramble on small screens
  printf '\033[?7l\033[38;2;84;17;17m'
  cat <<'EOF_LOGO'
       .-=*@@@@@@@@@+=:                                                                                            
    .=@@@=-...   ..:-+@@+-                                                                                         
   +@@-.   .           .+@@-                                                                                       
 :@@-     :@@-..          +@*                                                                                      
:@@.        :@@@@          =@@                                                                                     
@@=          :@@@@-         @@-                                                                                    
@@:           +@ :@@++:     +@+                                                                                    
@@=           +@  .@@@=     .-                                                                                     
.@@:          *@.        -:   :-         .-===:.  .-: --------:      .-----.   -------   .-==-:.    :-.    :-----. 
 :@@=        @@@@        -@@=@@-       :@@@===@+  -@@ -==@@@==-      -@@--+@@ .@@===== :@@@==+@:   =@@@.   @@@--@@@
   =@@=.      ::.          :=:         @@:  -====.:@@    +@=   ..... :@@==+@* .@@++=+: @@:        =@=.@@.  +@@--@@@
     -@@@+-:.    .:-=+@+               *@*. -=@@@ :@@    *@+  .@@@@+ :@@=@@=  :@@-:::. @@+.  .:  =@@++@@@. *@@---. 
        :=+@@@@@@@@@+-:                 -@@@@@@=  :@@    +@=         :@@  =@@..@@@@@@@  -@@@@@@-:@@.::.=@@ +@=     
EOF_LOGO
  # Re-enable line wrapping (\033[?7h) and reset color
  printf '\033[?7h\033[0m\n'

  cat <<EOF_USAGE
Usage: git-recap [options] [path ...]

Aggregate your local Git commit messages for daily standups.
Groups contributions into Features / Fixes / Docs / Refactors / etc.
Works entirely offline from local .git state.

Options:
  -s, --since <when>   Commits since this date (default: "1 day ago"
                       or \$GIT_RECAP_SINCE)
  -u, --until <when>   Commits until this date (optional; or \$GIT_RECAP_UNTIL)
      --today          Shortcut for --since "midnight"
      --yesterday      Show yesterday's commits (yesterday 00:00 to today 00:00)
      --week           Shortcut for --since "1 week ago"
      --max-length <n> Max summary bullet length (default: 88)
  -a, --author <who>   Override author match (default: git user.email / user.name
                       or \$GIT_RECAP_AUTHOR)
  -A, --all-authors    Include commits from every author (ignore author filter)
  -p, --plain          Paste-friendly output (no colors, no hashes)
      --color <when>   Colorize output: auto (default), always, or never
                       (\$NO_COLOR implies never unless --color=always)
      --summary-only   Only print the final standup summary block
      --flat           Skip smart grouping; print a flat commit list
  -r, --recursive      When scanning a folder, find Git repos at any depth
                       (skips node_modules, vendor, .terraform, dist, build)
      --include-merges Include merge commits (omitted by default)
      --reviews        Include your GitHub PR reviews via gh (optional network)
      --json           Machine-readable JSON summary (implies no color)
  -V, --version        Print version and exit
  -h, --help           Show this help

Examples:
  git-recap                          # smart standup summary
  git-recap project-a ~/code/app     # specific targets
  git-recap --today
  git-recap --yesterday
  git-recap --since "3 days ago" --until yesterday
  git-recap --plain                  # copy into Slack / notes
  git-recap --summary-only           # just the standup block
  git-recap --flat                   # raw commit list
  git-recap --author "Jane Doe"
  git-recap --all-authors --today    # whole-team window
  git-recap --reviews --today        # commits + your GitHub PR reviews
  git-recap -r --today               # deep-scan cwd for repos
  git-recap --json --today           # script-friendly output
EOF_USAGE
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -V|--version)
      printf 'git-recap %s\n' "$VERSION"
      exit 0
      ;;
    -s|--since)
      if [[ $# -lt 2 ]]; then
        echo "error: $1 requires an argument" >&2
        exit 1
      fi
      SINCE="$2"
      shift 2
      ;;
    --since=*)
      SINCE="${1#*=}"
      shift
      ;;
    -u|--until)
      if [[ $# -lt 2 ]]; then
        echo "error: $1 requires an argument" >&2
        exit 1
      fi
      UNTIL="$2"
      shift 2
      ;;
    --until=*)
      UNTIL="${1#*=}"
      shift
      ;;
    --today)
      SINCE="midnight"
      UNTIL=""
      shift
      ;;
    --yesterday)
      SINCE="yesterday 00:00"
      UNTIL="today 00:00"
      shift
      ;;
    --week)
      SINCE="1 week ago"
      UNTIL=""
      shift
      ;;
    --max-length)
      if [[ $# -lt 2 ]]; then
        echo "error: $1 requires an argument" >&2
        exit 1
      fi
      MAX_SUBJECT_LENGTH="$2"
      shift 2
      ;;
    --max-length=*)
      MAX_SUBJECT_LENGTH="${1#*=}"
      shift
      ;;
    -a|--author)
      if [[ $# -lt 2 ]]; then
        echo "error: $1 requires an argument" >&2
        exit 1
      fi
      AUTHOR_OVERRIDE="$2"
      ALL_AUTHORS=0
      shift 2
      ;;
    --author=*)
      AUTHOR_OVERRIDE="${1#*=}"
      ALL_AUTHORS=0
      shift
      ;;
    -A|--all-authors)
      ALL_AUTHORS=1
      AUTHOR_OVERRIDE=""
      shift
      ;;
    -p|--plain)
      PLAIN=1
      shift
      ;;
    --color)
      if [[ $# -lt 2 ]]; then
        echo "error: $1 requires an argument (auto|always|never)" >&2
        exit 1
      fi
      COLOR_MODE="$2"
      shift 2
      ;;
    --color=*)
      COLOR_MODE="${1#*=}"
      shift
      ;;
    --summary-only)
      SUMMARY_ONLY=1
      shift
      ;;
    --flat)
      FLAT=1
      shift
      ;;
    -r|--recursive)
      RECURSIVE=1
      shift
      ;;
    --include-merges)
      INCLUDE_MERGES=1
      shift
      ;;
    --reviews)
      INCLUDE_REVIEWS=1
      shift
      ;;
    --json)
      JSON=1
      shift
      ;;
    --)
      shift
      TARGETS+=("$@")
      break
      ;;
    -*)
      echo "error: unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      TARGETS+=("$1")
      shift
      ;;
  esac
done

case "$MAX_SUBJECT_LENGTH" in
  ''|*[!0-9]*)
    echo "error: --max-length must be a positive integer" >&2
    exit 1
    ;;
esac
if [[ "$MAX_SUBJECT_LENGTH" -lt 20 ]]; then
  echo "error: --max-length must be at least 20" >&2
  exit 1
fi

if [[ "$FLAT" -eq 1 && "$SUMMARY_ONLY" -eq 1 ]]; then
  echo "error: --flat and --summary-only cannot be used together" >&2
  exit 1
fi

if [[ "$JSON" -eq 1 && "$FLAT" -eq 1 ]]; then
  echo "error: --json and --flat cannot be used together" >&2
  exit 1
fi

case "$COLOR_MODE" in
  auto|always|never) ;;
  *)
    echo "error: --color must be auto, always, or never" >&2
    exit 1
    ;;
esac

# JSON is always plain/monochrome.
if [[ "$JSON" -eq 1 ]]; then
  PLAIN=1
  COLOR_MODE="never"
fi
# ---------------------------------------------------------------------------
# Colors (TTY / --color / NO_COLOR / --plain)
# ---------------------------------------------------------------------------
use_color=0
if [[ "$PLAIN" -eq 0 ]]; then
  if [[ "$COLOR_MODE" == "always" ]]; then
    use_color=1
  elif [[ "$COLOR_MODE" == "never" ]]; then
    use_color=0
  elif [[ -n "${NO_COLOR:-}" ]]; then
    use_color=0
  elif [[ -t 1 ]]; then
    use_color=1
  fi
fi

if [[ "$use_color" -eq 1 ]]; then
  BOLD=$'\033[1m'
  DIM=$'\033[2m'
  CYAN=$'\033[36m'
  GREEN=$'\033[32m'
  YELLOW=$'\033[33m'
  MAGENTA=$'\033[35m'
  BLUE=$'\033[34m'
  RESET=$'\033[0m'
else
  BOLD='' DIM='' CYAN='' GREEN='' YELLOW='' MAGENTA='' BLUE='' RESET=''
fi

# ---------------------------------------------------------------------------
# Author lookup
# ---------------------------------------------------------------------------
# Escape a string for git's --author regex matching.
escape_author_regex() {
  # Prefix regex metacharacters with a backslash.
  printf '%s' "$1" | sed -e 's/[][\.*^$+?(){}|]/\\&/g'
}

AUTHOR_NAME="$(git config user.name 2>/dev/null || true)"
AUTHOR_EMAIL="$(git config user.email 2>/dev/null || true)"

if [[ "$ALL_AUTHORS" -eq 1 ]]; then
  AUTHOR_REGEX=""
  DISPLAY_AUTHOR="all authors"
elif [[ -n "$AUTHOR_OVERRIDE" ]]; then
  AUTHOR_PATTERN="$AUTHOR_OVERRIDE"
  DISPLAY_AUTHOR="$AUTHOR_OVERRIDE"
  AUTHOR_REGEX="$(escape_author_regex "$AUTHOR_PATTERN")"
else
  AUTHOR_PATTERN="${AUTHOR_EMAIL:-$AUTHOR_NAME}"
  DISPLAY_AUTHOR="${AUTHOR_NAME:-$AUTHOR_EMAIL}"
  if [[ -z "$AUTHOR_PATTERN" ]]; then
    echo "error: git config user.email or git config user.name is not set" >&2
    echo "  run: git config --global user.email \"you@example.com\"" >&2
    echo "  or:  git config --global user.name \"Your Name\"" >&2
    echo "  or:  git-recap --author \"Your Name\"" >&2
    echo "  or:  git-recap --all-authors" >&2
    exit 1
  fi
  AUTHOR_REGEX="$(escape_author_regex "$AUTHOR_PATTERN")"
fi
# ---------------------------------------------------------------------------
# Classification and formatting
# ---------------------------------------------------------------------------
category_color() {
  case "$1" in
    Features) printf '%s' "$GREEN" ;;
    Fixes) printf '%s' "$YELLOW" ;;
    Docs) printf '%s' "$BLUE" ;;
    Refactors) printf '%s' "$MAGENTA" ;;
    Tests) printf '%s' "$CYAN" ;;
    Performance) printf '%s' "$GREEN" ;;
    Reviews) printf '%s' "$CYAN" ;;
    Chores|Other) printf '%s' "$DIM" ;;
    *) printf '%s' "$DIM" ;;
  esac
}

classify_commit() {
  local subject="$1" lower
  lower="$(printf '%s' "$subject" | tr '[:upper:]' '[:lower:]')"

  # Conventional Commits / typed prefixes first (highest confidence).
  case "$lower" in
    feat:*|feat!:*|feat\(*\):*|feat\(*\)!:*|feature:*|feature!:*|feature\(*\):*|feature\(*\)!:*)
      echo Features; return ;;
    fix:*|fix!:*|fix\(*\):*|fix\(*\)!:*|bugfix:*|bugfix!:*|hotfix:*|hotfix!:*)
      echo Fixes; return ;;
    doc:*|doc!:*|docs:*|docs!:*|doc\(*\):*|docs\(*\):*|doc\(*\)!:*|docs\(*\)!:*)
      echo Docs; return ;;
    refactor:*|refactor!:*|refactor\(*\):*|refactor\(*\)!:*)
      echo Refactors; return ;;
    test:*|test!:*|tests:*|tests!:*|test\(*\):*|tests\(*\):*|test\(*\)!:*|tests\(*\)!:*)
      echo Tests; return ;;
    perf:*|perf!:*|perf\(*\):*|perf\(*\)!:*)
      echo Performance; return ;;
    review:*|review!:*|reviews:*|reviews!:*|review\(*\):*|reviews\(*\):*|review\(*\)!:*|reviews\(*\)!:*)
      echo Reviews; return ;;
    chore:*|chore!:*|build:*|build!:*|ci:*|ci!:*|style:*|style!:*|dep:*|deps:*|chore\(*\):*|build\(*\):*|ci\(*\):*|style\(*\):*|deps\(*\):*)
      echo Chores; return ;;
  esac

  # Keyword heuristics — prefer leading verbs / clear phrases over substring matches
  # that false-positive (e.g. "prefix" → Fixes, "docker" → Docs).
  case "$lower" in
    fix\ *|fixed\ *|fixes\ *|bugfix\ *|hotfix\ *|repair\ *|resolve\ *|resolved\ *)
      echo Fixes ;;
    add\ *|added\ *|implement\ *|implemented\ *|introduce\ *|introduced\ *|create\ *|created\ *|feature\ *)
      echo Features ;;
    docs\ *|readme\ *|changelog\ *|document\ *|documented\ *)
      echo Docs ;;
    refactor\ *|refactored\ *|clean\ up\ *|simplify\ *|restructure\ *|rename\ *|extract\ *)
      echo Refactors ;;
    test\ *|tests\ *|spec\ *|coverage\ *)
      echo Tests ;;
    perf\ *|optimis*|*optimiz*|*performance*)
      echo Performance ;;
    review\ *|reviews\ *|code\ review*|*pull\ request\ review*|*pr\ review*|address*\ review*|address*\ feedback*)
      echo Reviews ;;
    chore\ *|bump\ *|deps\ *|dependenc*|*upgrade\ *|lint\ *|format\ *)
      echo Chores ;;
    *)
      echo Other ;;
  esac
}

clean_subject() {
  local subject="$1"
  subject="$(printf '%s' "$subject" | sed -E 's/^[A-Za-z]+(\([^)]*\))?!?:[[:space:]]+//')"
  if [[ "$subject" =~ ^[a-z] ]]; then
    subject="$(printf '%s' "${subject:0:1}" | tr '[:lower:]' '[:upper:]')${subject:1}"
  fi
  printf '%s' "$subject"
}

# Truncate at a word boundary when possible.
shorten_subject() {
  local subject="$1" max="$MAX_SUBJECT_LENGTH" cut
  if [[ ${#subject} -le "$max" ]]; then
    printf '%s' "$subject"
    return
  fi

  cut="${subject:0:$((max - 3))}"
  if [[ "$cut" == *' '* ]]; then
    cut="${cut% *}"
  fi
  if [[ ${#cut} -lt 12 ]]; then
    cut="${subject:0:$((max - 3))}"
  fi
  # Drop dangling separators left by the cut.
  cut="$(printf '%s' "$cut" | sed -E 's/[[:space:][:punct:]]+$//')"
  printf '%s...' "$cut"
}

timeframe_label() {
  if [[ -n "$UNTIL" ]]; then
    printf '%s to %s' "$SINCE" "$UNTIL"
  else
    printf 'since %s' "$SINCE"
  fi
}

format_bullet() {
  local subject="$1" hash="$2"
  if [[ "$PLAIN" -eq 1 ]]; then
    printf '    • %s\n' "$subject"
  else
    printf '    • %s (%s%s%s)\n' "$subject" "$DIM" "$hash" "$RESET"
  fi
}

record_global() {
  local cat="$1" repo="$2" subject="$3" hash="$4" line
  line="${repo}"$'\t'"${subject}"$'\t'"${hash}"$'\n'
  TOTAL_COMMITS=$((TOTAL_COMMITS + 1))
  case "$cat" in
    Features) G_FEATURES_COUNT=$((G_FEATURES_COUNT + 1)); G_FEATURES_ITEMS="${G_FEATURES_ITEMS}${line}" ;;
    Fixes) G_FIXES_COUNT=$((G_FIXES_COUNT + 1)); G_FIXES_ITEMS="${G_FIXES_ITEMS}${line}" ;;
    Docs) G_DOCS_COUNT=$((G_DOCS_COUNT + 1)); G_DOCS_ITEMS="${G_DOCS_ITEMS}${line}" ;;
    Refactors) G_REFACTORS_COUNT=$((G_REFACTORS_COUNT + 1)); G_REFACTORS_ITEMS="${G_REFACTORS_ITEMS}${line}" ;;
    Tests) G_TESTS_COUNT=$((G_TESTS_COUNT + 1)); G_TESTS_ITEMS="${G_TESTS_ITEMS}${line}" ;;
    Performance) G_PERFORMANCE_COUNT=$((G_PERFORMANCE_COUNT + 1)); G_PERFORMANCE_ITEMS="${G_PERFORMANCE_ITEMS}${line}" ;;
    Chores) G_CHORES_COUNT=$((G_CHORES_COUNT + 1)); G_CHORES_ITEMS="${G_CHORES_ITEMS}${line}" ;;
    Reviews) G_REVIEWS_COUNT=$((G_REVIEWS_COUNT + 1)); G_REVIEWS_ITEMS="${G_REVIEWS_ITEMS}${line}" ;;
    *) G_OTHER_COUNT=$((G_OTHER_COUNT + 1)); G_OTHER_ITEMS="${G_OTHER_ITEMS}${line}" ;;
  esac
}

# GitHub PR reviews (not local commits) — counted separately from TOTAL_COMMITS.
record_github_review() {
  local repo="$1" subject="$2" pr_ref="$3" line
  line="${repo}"$'\t'"${subject}"$'\t'"${pr_ref}"$'\n'
  TOTAL_REVIEWS=$((TOTAL_REVIEWS + 1))
  G_REVIEWS_COUNT=$((G_REVIEWS_COUNT + 1))
  G_REVIEWS_ITEMS="${G_REVIEWS_ITEMS}${line}"
}

# ---------------------------------------------------------------------------
# Repo helpers
# ---------------------------------------------------------------------------
has_git_dir() {
  [[ -e "${1}/.git" ]]
}

inside_git_repo() {
  git -C "${1:-.}" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

log_commits() {
  local git_dir="$1"
  # Build git log args without `local -a` quirks on Bash 3.2.
  local args=(log --pretty=format:%h%x09%s)
  if [[ -n "$AUTHOR_REGEX" ]]; then
    args+=(--author="$AUTHOR_REGEX")
  fi
  args+=(--since="$SINCE")
  if [[ -n "$UNTIL" ]]; then
    args+=(--until="$UNTIL")
  fi
  if [[ "$INCLUDE_MERGES" -eq 0 ]]; then
    args+=(--no-merges)
  fi
  git -C "$git_dir" "${args[@]}" 2>/dev/null || true
}

add_local_item() {
  local cat="$1" item="$2"
  case "$cat" in
    Features) FEATURES_COUNT=$((FEATURES_COUNT + 1)); FEATURES_ITEMS="${FEATURES_ITEMS}${item}" ;;
    Fixes) FIXES_COUNT=$((FIXES_COUNT + 1)); FIXES_ITEMS="${FIXES_ITEMS}${item}" ;;
    Docs) DOCS_COUNT=$((DOCS_COUNT + 1)); DOCS_ITEMS="${DOCS_ITEMS}${item}" ;;
    Refactors) REFACTORS_COUNT=$((REFACTORS_COUNT + 1)); REFACTORS_ITEMS="${REFACTORS_ITEMS}${item}" ;;
    Tests) TESTS_COUNT=$((TESTS_COUNT + 1)); TESTS_ITEMS="${TESTS_ITEMS}${item}" ;;
    Performance) PERFORMANCE_COUNT=$((PERFORMANCE_COUNT + 1)); PERFORMANCE_ITEMS="${PERFORMANCE_ITEMS}${item}" ;;
    Chores) CHORES_COUNT=$((CHORES_COUNT + 1)); CHORES_ITEMS="${CHORES_ITEMS}${item}" ;;
    Reviews) REVIEWS_COUNT=$((REVIEWS_COUNT + 1)); REVIEWS_ITEMS="${REVIEWS_ITEMS}${item}" ;;
    *) OTHER_COUNT=$((OTHER_COUNT + 1)); OTHER_ITEMS="${OTHER_ITEMS}${item}" ;;
  esac
}

count_for_category() {
  case "$1" in
    Features) echo "$FEATURES_COUNT" ;;
    Fixes) echo "$FIXES_COUNT" ;;
    Docs) echo "$DOCS_COUNT" ;;
    Refactors) echo "$REFACTORS_COUNT" ;;
    Tests) echo "$TESTS_COUNT" ;;
    Performance) echo "$PERFORMANCE_COUNT" ;;
    Chores) echo "$CHORES_COUNT" ;;
    Reviews) echo "$REVIEWS_COUNT" ;;
    *) echo "$OTHER_COUNT" ;;
  esac
}

items_for_category() {
  case "$1" in
    Features) printf '%s' "$FEATURES_ITEMS" ;;
    Fixes) printf '%s' "$FIXES_ITEMS" ;;
    Docs) printf '%s' "$DOCS_ITEMS" ;;
    Refactors) printf '%s' "$REFACTORS_ITEMS" ;;
    Tests) printf '%s' "$TESTS_ITEMS" ;;
    Performance) printf '%s' "$PERFORMANCE_ITEMS" ;;
    Chores) printf '%s' "$CHORES_ITEMS" ;;
    Reviews) printf '%s' "$REVIEWS_ITEMS" ;;
    *) printf '%s' "$OTHER_ITEMS" ;;
  esac
}

recap_repo() {
  local dir="$1" require_git_dir="${2:-0}"
  local git_dir label commits hash subject cat cleaned short item count color
  local repo_count=0 noun

  FEATURES_COUNT=0; FIXES_COUNT=0; DOCS_COUNT=0; REFACTORS_COUNT=0
  TESTS_COUNT=0; PERFORMANCE_COUNT=0; CHORES_COUNT=0; REVIEWS_COUNT=0; OTHER_COUNT=0
  FEATURES_ITEMS=''; FIXES_ITEMS=''; DOCS_ITEMS=''; REFACTORS_ITEMS=''
  TESTS_ITEMS=''; PERFORMANCE_ITEMS=''; CHORES_ITEMS=''; REVIEWS_ITEMS=''; OTHER_ITEMS=''

  if has_git_dir "$dir"; then
    git_dir="$dir"
  elif [[ "$require_git_dir" -eq 0 ]] && inside_git_repo "$dir"; then
    git_dir="$(git -C "$dir" rev-parse --show-toplevel)"
  else
    return 1
  fi

  if [[ "$git_dir" == "." || "$git_dir" != /* ]]; then
    git_dir="$(cd "$git_dir" && pwd)"
  fi

  commits="$(log_commits "$git_dir")"
  if [[ -z "$commits" ]]; then
    return 1
  fi

  label="$(basename "$git_dir")"

  # Collect first so we can show an accurate commit count in the header.
  # `|| [[ -n ... ]]` keeps the last line when pretty-format omits a trailing newline.
  while IFS=$'\t' read -r hash subject || [[ -n "${hash:-}" ]]; do
    [[ -z "${hash:-}" ]] && continue
    cat="$(classify_commit "$subject")"
    cleaned="$(clean_subject "$subject")"
    short="$(shorten_subject "$cleaned")"
    record_global "$cat" "$label" "$short" "$hash"
    repo_count=$((repo_count + 1))

    if [[ "$FLAT" -eq 1 ]]; then
      item="${subject}"$'\t'"${hash}"$'\n'
    else
      item="${short}"$'\t'"${hash}"$'\n'
    fi
    add_local_item "$cat" "$item"
    hash=''
    subject=''
  done <<< "$commits"

  PRINTED_REPOS=$((PRINTED_REPOS + 1))

  # JSON mode / --summary-only accumulate globally and skip per-repo detail.
  if [[ "$SUMMARY_ONLY" -eq 1 || "$JSON" -eq 1 ]]; then
    return 0
  fi

  noun="commits"
  [[ "$repo_count" -eq 1 ]] && noun="commit"
  printf '\n%s%s%s%s %s· %s %s · %s%s\n' \
    "$BOLD" "$CYAN" "$label" "$RESET" "$DIM" "$repo_count" "$noun" "$(timeframe_label)" "$RESET"
  printf '%s%s%s\n' "$DIM" "────────────────────────────────────────" "$RESET"

  if [[ "$FLAT" -eq 1 ]]; then
    while IFS=$'\t' read -r hash subject || [[ -n "${hash:-}" ]]; do
      [[ -z "${hash:-}" ]] && continue
      if [[ "$PLAIN" -eq 1 ]]; then
        printf '  • %s\n' "$subject"
      else
        printf '  • %s (%s%s%s)\n' "$subject" "$DIM" "$hash" "$RESET"
      fi
      hash=''
      subject=''
    done <<< "$commits"
    return 0
  fi

  for cat in "${CATEGORIES[@]}"; do
    count="$(count_for_category "$cat")"
    [[ "$count" -eq 0 ]] && continue
    color="$(category_color "$cat")"
    printf '  %s%s%s (%s)\n' "$BOLD$color" "$cat" "$RESET" "$count"

    while IFS=$'\t' read -r subject hash || [[ -n "${hash:-}" ]]; do
      [[ -z "${hash:-}" ]] && continue
      format_bullet "$subject" "$hash"
      hash=''
      subject=''
    done <<< "$(items_for_category "$cat")"
  done

  return 0
}

scan_subdirs() {
  local parent="$1" entry
  shopt -s nullglob
  for entry in "$parent"/*/; do
    entry="${entry%/}"
    if has_git_dir "$entry"; then
      printf '%s\0' "$entry"
    fi
  done
  shopt -u nullglob
}

# Deep scan: find .git dirs/files, skip heavy/vendor trees.
scan_subdirs_recursive() {
  local parent="$1" git_entry repo
  # Prefer find when available (macOS / Linux).
  if ! command -v find >/dev/null 2>&1; then
    scan_subdirs "$parent"
    return
  fi
  while IFS= read -r -d '' git_entry; do
    repo="$(dirname "$git_entry")"
    printf '%s\0' "$repo"
  done < <(
    find "$parent" \
      \( -name node_modules -o -name vendor -o -name .terraform -o -name dist -o -name build -o -name .next -o -name target \) -prune -o \
      \( \( -name .git -type d \) -o \( -name .git -type f \) \) -print0 2>/dev/null
  )
}

json_escape() {
  # Escape a string for JSON (Bash 3.2-safe, no printf %q).
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\t'/\\t}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\n'/\\n}"
  printf '%s' "$s"
}

print_json() {
  local cat count first_cat=1 first_item repo subject hash
  local all_authors_json="false" include_merges_json="false" include_reviews_json="false"
  [[ "$ALL_AUTHORS" -eq 1 ]] && all_authors_json="true"
  [[ "$INCLUDE_MERGES" -eq 1 ]] && include_merges_json="true"
  [[ "$INCLUDE_REVIEWS" -eq 1 ]] && include_reviews_json="true"

  printf '{\n'
  printf '  "version": "%s",\n' "$(json_escape "$VERSION")"
  printf '  "author": "%s",\n' "$(json_escape "$DISPLAY_AUTHOR")"
  printf '  "all_authors": %s,\n' "$all_authors_json"
  printf '  "since": "%s",\n' "$(json_escape "$SINCE")"
  printf '  "until": "%s",\n' "$(json_escape "$UNTIL")"
  printf '  "include_merges": %s,\n' "$include_merges_json"
  printf '  "include_reviews": %s,\n' "$include_reviews_json"
  printf '  "timeframe": "%s",\n' "$(json_escape "$(timeframe_label)")"
  printf '  "total_commits": %s,\n' "$TOTAL_COMMITS"
  printf '  "total_reviews": %s,\n' "$TOTAL_REVIEWS"
  printf '  "repos_with_commits": %s,\n' "$PRINTED_REPOS"
  printf '  "categories": {\n'

  for cat in "${CATEGORIES[@]}"; do
    count="$(global_count_for_category "$cat")"
    [[ "$count" -eq 0 ]] && continue
    if [[ "$first_cat" -eq 0 ]]; then
      printf ',\n'
    fi
    first_cat=0
    printf '    "%s": [\n' "$(json_escape "$cat")"
    first_item=1
    while IFS=$'\t' read -r repo subject hash || [[ -n "${hash:-}" ]]; do
      [[ -z "${hash:-}" ]] && continue
      if [[ "$first_item" -eq 0 ]]; then
        printf ',\n'
      fi
      first_item=0
      printf '      {"repo":"%s","subject":"%s","hash":"%s"}' \
        "$(json_escape "$repo")" \
        "$(json_escape "$subject")" \
        "$(json_escape "$hash")"
      hash=''
      subject=''
      repo=''
    done <<< "$(global_items_for_category "$cat")"
    printf '\n    ]'
  done

  if [[ "$first_cat" -eq 1 ]]; then
    printf '  }\n'
  else
    printf '\n  }\n'
  fi
  printf '}\n'
}

global_count_for_category() {
  case "$1" in
    Features) echo "$G_FEATURES_COUNT" ;;
    Fixes) echo "$G_FIXES_COUNT" ;;
    Docs) echo "$G_DOCS_COUNT" ;;
    Refactors) echo "$G_REFACTORS_COUNT" ;;
    Tests) echo "$G_TESTS_COUNT" ;;
    Performance) echo "$G_PERFORMANCE_COUNT" ;;
    Chores) echo "$G_CHORES_COUNT" ;;
    Reviews) echo "$G_REVIEWS_COUNT" ;;
    *) echo "$G_OTHER_COUNT" ;;
  esac
}

global_items_for_category() {
  case "$1" in
    Features) printf '%s' "$G_FEATURES_ITEMS" ;;
    Fixes) printf '%s' "$G_FIXES_ITEMS" ;;
    Docs) printf '%s' "$G_DOCS_ITEMS" ;;
    Refactors) printf '%s' "$G_REFACTORS_ITEMS" ;;
    Tests) printf '%s' "$G_TESTS_ITEMS" ;;
    Performance) printf '%s' "$G_PERFORMANCE_ITEMS" ;;
    Chores) printf '%s' "$G_CHORES_ITEMS" ;;
    Reviews) printf '%s' "$G_REVIEWS_ITEMS" ;;
    *) printf '%s' "$G_OTHER_ITEMS" ;;
  esac
}

activity_counts_label() {
  local parts="" noun
  if [[ "$TOTAL_COMMITS" -gt 0 ]]; then
    noun="commits"
    [[ "$TOTAL_COMMITS" -eq 1 ]] && noun="commit"
    parts="${TOTAL_COMMITS} ${noun}"
  fi
  if [[ "$TOTAL_REVIEWS" -gt 0 ]]; then
    noun="reviews"
    [[ "$TOTAL_REVIEWS" -eq 1 ]] && noun="review"
    if [[ -n "$parts" ]]; then
      parts="${parts} · ${TOTAL_REVIEWS} ${noun}"
    else
      parts="${TOTAL_REVIEWS} ${noun}"
    fi
  fi
  if [[ -z "$parts" ]]; then
    parts="0 commits"
  fi
  printf '%s' "$parts"
}

print_standup_summary() {
  local cat count color repo subject hash
  [[ "$FLAT" -eq 1 ]] && return
  [[ "$TOTAL_COMMITS" -eq 0 && "$TOTAL_REVIEWS" -eq 0 ]] && return

  # Single-repo smart mode already printed the grouped view — avoid duplication
  # unless the user explicitly asked for --summary-only, or reviews were added
  # after the per-repo block.
  if [[ "$SUMMARY_ONLY" -eq 0 && "$PRINTED_REPOS" -le 1 && "$TOTAL_REVIEWS" -eq 0 ]]; then
    return
  fi
  # When only reviews exist (no commit repos printed), still show the block.
  if [[ "$SUMMARY_ONLY" -eq 0 && "$PRINTED_REPOS" -le 1 && "$TOTAL_COMMITS" -gt 0 && "$TOTAL_REVIEWS" -gt 0 ]]; then
    # Reviews-only appendix after a single-repo print.
    print_reviews_section
    return
  fi

  printf '\n%sStandup summary%s %s· %s · %s%s\n' \
    "$BOLD" "$RESET" "$DIM" "$(activity_counts_label)" "$(timeframe_label)" "$RESET"
  printf '%s%s%s\n' "$DIM" "────────────────────────────────────────" "$RESET"

  for cat in "${CATEGORIES[@]}"; do
    count="$(global_count_for_category "$cat")"
    [[ "$count" -eq 0 ]] && continue
    color="$(category_color "$cat")"
    printf '  %s%s%s (%s)\n' "$BOLD$color" "$cat" "$RESET" "$count"

    while IFS=$'\t' read -r repo subject hash || [[ -n "${hash:-}" ]]; do
      [[ -z "${hash:-}" ]] && continue
      if [[ "$PRINTED_REPOS" -gt 1 || "$cat" == "Reviews" ]]; then
        if [[ "$PLAIN" -eq 1 ]]; then
          printf '    • %s: %s\n' "$repo" "$subject"
        else
          printf '    • %s%s%s: %s\n' "$DIM" "$repo" "$RESET" "$subject"
        fi
      else
        format_bullet "$subject" "$hash"
      fi
      hash=''
      subject=''
      repo=''
    done <<< "$(global_items_for_category "$cat")"
  done
}

print_reviews_section() {
  local count color repo subject hash
  count="$TOTAL_REVIEWS"
  [[ "$count" -eq 0 ]] && return

  color="$(category_color Reviews)"
  printf '\n%sReviews%s %s· %s · %s%s\n' \
    "$BOLD" "$RESET" "$DIM" "$(activity_counts_label)" "$(timeframe_label)" "$RESET"
  printf '%s%s%s\n' "$DIM" "────────────────────────────────────────" "$RESET"
  printf '  %s%s%s (%s)\n' "$BOLD$color" "Reviews" "$RESET" "$count"

  while IFS=$'\t' read -r repo subject hash || [[ -n "${hash:-}" ]]; do
    [[ -z "${hash:-}" ]] && continue
    # Only print GitHub review lines from the shared Reviews bucket by matching PR# refs.
    case "$hash" in
      PR#*) ;;
      *) hash=''; subject=''; repo=''; continue ;;
    esac
    if [[ "$PLAIN" -eq 1 ]]; then
      printf '    • %s: %s\n' "$repo" "$subject"
    else
      printf '    • %s%s%s: %s\n' "$DIM" "$repo" "$RESET" "$subject"
    fi
    hash=''
    subject=''
    repo=''
  done <<< "$(global_items_for_category Reviews)"
}

# Convert git approxidates / presets to UTC ISO-8601 for GitHub GraphQL.
approxidate_to_iso() {
  local when="$1"
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$when" <<'PY'
import re, sys
from datetime import datetime, timedelta, timezone
when = sys.argv[1].strip()
now = datetime.now(timezone.utc)
low = when.lower()

def emit(dt):
    print(dt.astimezone(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"))

if re.match(r"^\d{4}-\d{2}-\d{2}([tT ].*)?$", when):
    text = when.replace(" ", "T")
    if text.endswith("Z") or re.search(r"[+-]\d{2}:?\d{2}$", text):
        dt = datetime.fromisoformat(text.replace("Z", "+00:00"))
    else:
        if "T" not in text:
            text += "T00:00:00"
        dt = datetime.fromisoformat(text).replace(tzinfo=timezone.utc)
    emit(dt)
    raise SystemExit(0)

m = re.match(r"^(\d+)\s+(seconds?|minutes?|hours?|days?|weeks?|months?|years?)\s+ago$", low)
if m:
    n = int(m.group(1))
    unit = m.group(2).rstrip("s")
    seconds = {
        "second": 1, "minute": 60, "hour": 3600, "day": 86400,
        "week": 604800, "month": 2592000, "year": 31536000,
    }[unit]
    emit(now - timedelta(seconds=n * seconds))
    raise SystemExit(0)

if low in ("midnight", "today", "today 00:00"):
    emit(now.replace(hour=0, minute=0, second=0, microsecond=0))
    raise SystemExit(0)
if low in ("yesterday", "yesterday 00:00"):
    emit((now - timedelta(days=1)).replace(hour=0, minute=0, second=0, microsecond=0))
    raise SystemExit(0)

print("")
raise SystemExit(1)
PY
    return
  fi
  return 1
}

review_verb_for_state() {
  case "$1" in
    APPROVED) echo "Approved" ;;
    CHANGES_REQUESTED) echo "Requested changes on" ;;
    COMMENTED) echo "Reviewed" ;;
    DISMISSED) echo "Dismissed review on" ;;
    *) echo "Reviewed" ;;
  esac
}

reviews_is_tty() {
  [[ -t 0 && -t 2 ]]
}

reviews_prompt() {
  # $1 = prompt text. Reads a line from the terminal into REPLY_LINE.
  local prompt="$1"
  REPLY_LINE=""
  if ! reviews_is_tty; then
    return 1
  fi
  printf '%s' "$prompt" >&2
  # Read from the controlling terminal so pipes/JSON don't eat input.
  if [[ -r /dev/tty ]]; then
    IFS= read -r REPLY_LINE < /dev/tty || return 1
  else
    IFS= read -r REPLY_LINE || return 1
  fi
  return 0
}

reviews_pause() {
  local msg="${1:-Press Enter to continue… }"
  reviews_prompt "$msg" || return 1
  return 0
}

reviews_confirm() {
  # Returns 0 if user answers y/yes (default y when empty and $2=y).
  local prompt="$1" default="${2:-y}" answer
  reviews_prompt "$prompt" || return 1
  answer="$(printf '%s' "$REPLY_LINE" | tr '[:upper:]' '[:lower:]')"
  if [[ -z "$answer" ]]; then
    answer="$default"
  fi
  case "$answer" in
    y|yes) return 0 ;;
    *) return 1 ;;
  esac
}

# Consistent step success / failure display for the setup wizard.
reviews_step_ok() {
  echo "    OK: $1" >&2
}

reviews_step_fail() {
  # usage: reviews_step_fail "Step name" "Why it failed" ["Detail/output"] ["What to do next"]
  local step="$1" why="$2" detail="${3:-}" fix="${4:-}"
  echo >&2
  echo "    ERROR: ${step}" >&2
  echo "    -------" >&2
  echo "    Why:  ${why}" >&2
  if [[ -n "$detail" ]]; then
    echo "    Detail:" >&2
    printf '%s\n' "$detail" | sed 's/^/      /' >&2
  fi
  if [[ -n "$fix" ]]; then
    echo "    Next:" >&2
    printf '%s\n' "$fix" | sed 's/^/      /' >&2
  fi
  echo >&2
}

reviews_indent_cmd() {
  # Run a command, print its output indented; return its exit status.
  # Captures combined stdout+stderr into REVIEWS_CMD_OUT.
  local status=0
  REVIEWS_CMD_OUT="$("$@" 2>&1)" || status=$?
  if [[ -n "$REVIEWS_CMD_OUT" ]]; then
    printf '%s\n' "$REVIEWS_CMD_OUT" | sed 's/^/      /' >&2
  fi
  return "$status"
}

reviews_gh_installed() {
  command -v gh >/dev/null 2>&1
}

reviews_gh_authenticated() {
  gh auth status >/dev/null 2>&1
}

reviews_gh_auth_detail() {
  gh auth status 2>&1 || true
}

reviews_gh_api_ok() {
  local login
  login="$(gh api user --jq .login 2>/dev/null || true)"
  [[ -n "$login" ]]
}

reviews_gh_api_detail() {
  gh api user 2>&1 || true
}

reviews_python_ok() {
  command -v python3 >/dev/null 2>&1
}

reviews_ssh_github_ok() {
  # ssh -T exits 1 even on success; look for the success banner.
  local out
  out="$(ssh -o BatchMode=yes -o StrictHostKeyChecking=accept-new -T git@github.com 2>&1 || true)"
  printf '%s' "$out" | grep -Eqi 'successfully authenticated|Hi [^!]+!'
}

reviews_ssh_github_detail() {
  ssh -o BatchMode=yes -o StrictHostKeyChecking=accept-new -T git@github.com 2>&1 || true
}

reviews_explain_ssh_failure() {
  # Best-effort explanation from ssh -T output.
  local out="$1"
  case "$out" in
    *"Permission denied (publickey)"*)
      printf '%s\n' "GitHub rejected the key (Permission denied)."
      printf '%s\n' "The public key is not on your account, or ssh is offering a different key."
      ;;
    *"Could not resolve hostname"*)
      printf '%s\n' "DNS/network failed resolving github.com."
      ;;
    *"Connection timed out"*|*"Operation timed out"*)
      printf '%s\n' "Network timed out reaching github.com:22 (firewall/VPN/offline?)."
      ;;
    *"Host key verification failed"*)
      printf '%s\n' "SSH host key for github.com is not trusted yet."
      ;;
    *)
      printf '%s\n' "ssh -T git@github.com did not report a successful login."
      ;;
  esac
}

reviews_find_ssh_pubkey() {
  local key
  for key in "$HOME/.ssh/id_ed25519.pub" "$HOME/.ssh/id_rsa.pub" "$HOME/.ssh/id_ecdsa.pub"; do
    if [[ -f "$key" ]]; then
      printf '%s' "$key"
      return 0
    fi
  done
  return 1
}

# Static guidance when stdin is not a TTY (CI, pipes, scripts).
reviews_setup_help() {
  local reason="$1"
  echo >&2
  echo "ERROR: --reviews unavailable (${reason})" >&2
  echo "-------" >&2
  echo "Why:  Prerequisites for fetching GitHub PR reviews are missing or failed." >&2
  echo "Next: Re-run in an interactive terminal for step-by-step setup, or run:" >&2
  cat >&2 <<'EOF'
      brew install gh && gh auth login && gh auth status
      # optional SSH for git@ remotes:
      ssh-keygen -t ed25519 -C "you@example.com"
      # add ~/.ssh/id_ed25519.pub at https://github.com/settings/ssh/new
      ssh -T git@github.com
      git-recap --reviews --today
EOF
  echo >&2
}

reviews_setup_python() {
  local out

  echo >&2
  echo "==> Step: Python 3 (needed to parse review timestamps)" >&2
  if reviews_python_ok; then
    reviews_step_ok "$(python3 --version 2>&1)"
    return 0
  fi
  echo "    Missing: python3 is not on PATH." >&2

  if command -v brew >/dev/null 2>&1; then
    if reviews_confirm "    Install with Homebrew now? [Y/n] " y; then
      echo "    Running: brew install python" >&2
      if ! reviews_indent_cmd brew install python; then
        reviews_step_fail "Install Python 3" \
          "Homebrew could not install Python." \
          "${REVIEWS_CMD_OUT}" \
          "Fix brew (brew doctor), or install manually, then re-run:
  brew install python
  python3 --version
  git-recap --reviews --today"
        return 1
      fi
    else
      reviews_step_fail "Install Python 3" \
        "You declined the Homebrew install, and python3 is still missing." \
        "" \
        "Install Python 3, confirm it works, then re-run:
  brew install python
  python3 --version
  git-recap --reviews --today"
      return 1
    fi
  else
    echo "    Homebrew is not available — install Python 3 for your OS." >&2
    reviews_pause "    Press Enter after installing python3… " || {
      reviews_step_fail "Install Python 3" \
        "Setup was cancelled before Python could be verified." \
        "" \
        "Install Python 3, then re-run: git-recap --reviews --today"
      return 1
    }
  fi

  if reviews_python_ok; then
    reviews_step_ok "$(python3 --version 2>&1)"
    return 0
  fi

  out="$(command -v python3 2>&1 || true; type python3 2>&1 || true; echo "PATH=$PATH")"
  reviews_step_fail "Verify Python 3" \
    "python3 is still not available after the install step." \
    "$out" \
    "Open a new terminal tab (PATH may be stale), then:
  which python3
  python3 --version
If needed: brew install python && brew link python
Then: git-recap --reviews --today"
  return 1
}

reviews_setup_gh() {
  local out login

  echo >&2
  echo "==> Step: GitHub CLI (required for --reviews)" >&2
  echo "    Reviews are fetched via the GitHub API using gh — not SSH alone." >&2

  if ! reviews_gh_installed; then
    echo "    Missing: gh is not installed (or not on PATH)." >&2
    if command -v brew >/dev/null 2>&1; then
      if reviews_confirm "    Install gh with Homebrew now? [Y/n] " y; then
        echo "    Running: brew install gh" >&2
        if ! reviews_indent_cmd brew install gh; then
          reviews_step_fail "Install GitHub CLI" \
            "Homebrew could not install gh." \
            "${REVIEWS_CMD_OUT}" \
            "Try:
  brew update && brew install gh
  # or download from https://github.com/cli/cli#installation
Then confirm: which gh && gh --version"
          return 1
        fi
      else
        echo "    Install manually, then continue:" >&2
        echo "      brew install gh" >&2
        echo "      # or: https://github.com/cli/cli#installation" >&2
        reviews_pause "    Press Enter after installing gh… " || {
          reviews_step_fail "Install GitHub CLI" \
            "Setup was cancelled before gh could be verified." \
            "" \
            "Install gh, then re-run: git-recap --reviews --today"
          return 1
        }
      fi
    else
      echo "    Install gh from https://github.com/cli/cli#installation" >&2
      reviews_pause "    Press Enter after installing gh… " || {
        reviews_step_fail "Install GitHub CLI" \
          "Setup was cancelled before gh could be verified." \
          "" \
          "Install gh from https://github.com/cli/cli#installation
Then: git-recap --reviews --today"
        return 1
      }
    fi
  fi

  if ! reviews_gh_installed; then
    out="$(echo "which gh: $(command -v gh 2>&1 || echo 'not found')"; echo "PATH=$PATH")"
    reviews_step_fail "Verify GitHub CLI on PATH" \
      "gh is still not found after the install step." \
      "$out" \
      "Open a new terminal (shell PATH may be stale), then:
  which gh
  gh --version
If brew installed it: brew --prefix gh
Add that bin dir to PATH, then re-run git-recap --reviews --today"
    return 1
  fi
  reviews_step_ok "gh $(gh --version 2>/dev/null | head -1)"

  if reviews_gh_authenticated && reviews_gh_api_ok; then
    reviews_step_ok "authenticated as $(gh api user --jq .login 2>/dev/null)"
    return 0
  fi

  echo "    Missing: not signed in to GitHub, or the token expired / lacks access." >&2
  out="$(reviews_gh_auth_detail)"
  if [[ -n "$out" ]]; then
    echo "    Current gh auth status:" >&2
    printf '%s\n' "$out" | sed 's/^/      /' >&2
  fi
  echo "    Next: gh auth login  (browser or token; HTTPS is fine for reviews)." >&2

  if reviews_confirm "    Run gh auth login now? [Y/n] " y; then
    echo "    Running: gh auth login" >&2
    if [[ -r /dev/tty && -w /dev/tty ]]; then
      gh auth login < /dev/tty > /dev/tty 2>&1 || true
    else
      gh auth login || true
    fi
  else
    echo "    Run in another terminal: gh auth login" >&2
    reviews_pause "    Press Enter after signing in… " || {
      reviews_step_fail "GitHub authentication" \
        "Setup was cancelled before login could be verified." \
        "$(reviews_gh_auth_detail)" \
        "Run: gh auth login
Confirm: gh auth status
Then: git-recap --reviews --today"
      return 1
    }
  fi

  if ! reviews_gh_authenticated; then
    reviews_step_fail "Verify gh authentication" \
      "gh still reports that you are not logged in (or the host has no valid token)." \
      "$(reviews_gh_auth_detail)" \
      "Sign in again and refresh scopes:
  gh auth login
  gh auth refresh -h github.com -s repo
  gh auth status
If you use GitHub Enterprise, pass the correct hostname to gh auth login."
    return 1
  fi
  reviews_step_ok "gh auth status looks good"

  if ! reviews_gh_api_ok; then
    reviews_step_fail "Verify GitHub API access" \
      "Authenticated, but gh api user failed — token, scopes, or network problem." \
      "$(reviews_gh_api_detail)" \
      "Check connectivity to api.github.com, then:
  gh auth refresh -h github.com -s repo
  gh api user --jq .login
Corporate proxy/VPN: configure HTTPS_PROXY or allow api.github.com."
    return 1
  fi
  login="$(gh api user --jq .login 2>/dev/null)"
  reviews_step_ok "API works — signed in as ${login}"
  return 0
}

reviews_setup_ssh() {
  local pubkey email keyfile out why

  echo >&2
  echo "==> Step: SSH key for GitHub (optional — for git clone/push via git@…)" >&2
  echo "    Note: SSH does not replace gh for --reviews; it only unlocks SSH remotes." >&2

  if reviews_ssh_github_ok; then
    reviews_step_ok "ssh -T git@github.com already succeeds"
    return 0
  fi

  pubkey="$(reviews_find_ssh_pubkey || true)"
  if [[ -z "$pubkey" ]]; then
    echo "    Missing: no SSH public key in ~/.ssh/ (id_ed25519/id_rsa/id_ecdsa)." >&2
    if reviews_confirm "    Generate a new ed25519 key now? [Y/n] " y; then
      email=""
      while [[ -z "$email" ]]; do
        reviews_prompt "    Email for the key comment (e.g. you@example.com): " || {
          reviews_step_fail "SSH key email" \
            "Setup was cancelled before a key comment email was provided." \
            "" \
            "Re-run and enter the email you use on GitHub, or create a key manually:
  ssh-keygen -t ed25519 -C \"you@example.com\""
          return 1
        }
        email="$(printf '%s' "$REPLY_LINE" | tr -d '[:space:]')"
        if [[ -z "$email" || "$email" != *@* ]]; then
          reviews_step_fail "SSH key email" \
            "That does not look like an email address." \
            "Got: '${REPLY_LINE}'" \
            "Enter something like you@example.com (used only as the key comment)."
          email=""
        fi
      done
      keyfile="$HOME/.ssh/id_ed25519"
      mkdir -p "$HOME/.ssh"
      chmod 700 "$HOME/.ssh" 2>/dev/null || true
      if [[ -f "$keyfile" ]]; then
        echo "    Note: $keyfile already exists — not overwriting." >&2
      else
        echo "    Running: ssh-keygen -t ed25519 -f $keyfile -C \"$email\"" >&2
        if ! reviews_indent_cmd ssh-keygen -t ed25519 -f "$keyfile" -C "$email" -N ""; then
          reviews_step_fail "Generate SSH key" \
            "ssh-keygen failed to create ${keyfile}." \
            "${REVIEWS_CMD_OUT}" \
            "Check permissions on ~/.ssh (should be 700) and disk space, then:
  mkdir -p ~/.ssh && chmod 700 ~/.ssh
  ssh-keygen -t ed25519 -C \"${email}\""
          return 1
        fi
        reviews_step_ok "created $keyfile"
      fi
      pubkey="${keyfile}.pub"
    else
      reviews_step_fail "SSH key setup" \
        "You declined key generation, and no existing public key was found." \
        "" \
        "Either generate a key:
  ssh-keygen -t ed25519 -C \"you@example.com\"
Or skip SSH (optional) and use GitHub CLI only for --reviews."
      return 1
    fi
  else
    reviews_step_ok "found public key $pubkey"
  fi

  if [[ ! -f "$pubkey" ]]; then
    reviews_step_fail "Locate SSH public key" \
      "Expected public key file is missing." \
      "Looked for: $pubkey" \
      "Create one with ssh-keygen, then re-run this step."
    return 1
  fi

  echo >&2
  echo "    Add this public key on GitHub → SSH keys:" >&2
  echo "      https://github.com/settings/ssh/new" >&2
  echo "    ---- public key ----" >&2
  cat "$pubkey" >&2
  echo "    -------------------" >&2
  if command -v pbcopy >/dev/null 2>&1; then
    if reviews_confirm "    Copy the key to the clipboard with pbcopy? [Y/n] " y; then
      if pbcopy < "$pubkey"; then
        reviews_step_ok "copied to clipboard"
      else
        reviews_step_fail "Copy SSH public key" \
          "pbcopy failed — copy the key manually from the block above." \
          "" \
          "Select the key text, copy it, paste at https://github.com/settings/ssh/new"
      fi
    fi
  fi

  while true; do
    reviews_pause "    Press Enter after adding the key on GitHub (or type s to skip)… " || {
      reviews_step_fail "SSH verification" \
        "Setup was cancelled before GitHub SSH could be verified." \
        "" \
        "Add the key at https://github.com/settings/ssh/new then:
  ssh -T git@github.com"
      return 1
    }
    case "$(printf '%s' "$REPLY_LINE" | tr '[:upper:]' '[:lower:]')" in
      s|skip)
        reviews_step_fail "SSH verification" \
          "You skipped SSH verification." \
          "" \
          "SSH is optional for --reviews. Continue with GitHub CLI, or later run:
  ssh -T git@github.com"
        return 1
        ;;
    esac
    echo "    Verifying: ssh -T git@github.com …" >&2
    out="$(reviews_ssh_github_detail)"
    printf '%s\n' "$out" | sed 's/^/      /' >&2
    if printf '%s' "$out" | grep -Eqi 'successfully authenticated|Hi [^!]+!'; then
      reviews_step_ok "GitHub SSH authentication works"
      return 0
    fi
    why="$(reviews_explain_ssh_failure "$out")"
    reviews_step_fail "Verify SSH → GitHub" \
      "$why" \
      "$out" \
      "1. Confirm the EXACT public key above is saved at https://github.com/settings/keys
2. If you have multiple keys, force this one:
     ssh -i ~/.ssh/id_ed25519 -T git@github.com
3. Agent: ssh-add --apple-use-keychain ~/.ssh/id_ed25519   # macOS
4. Retry this check, or skip SSH and rely on gh for --reviews."
    if ! reviews_confirm "    Retry verification? [Y/n] " y; then
      return 1
    fi
  done
}

# Interactive wizard: choose GitHub CLI and/or SSH, verify every step.
reviews_setup_wizard() {
  local choice gh_ok=0

  echo >&2
  echo "git-recap --reviews setup" >&2
  echo "-------------------------" >&2
  echo "PR reviews need the GitHub CLI (API). SSH is optional for git@ remotes." >&2
  echo >&2
  echo "  1) GitHub CLI only   (recommended — unlocks --reviews)" >&2
  echo "  2) SSH key only      (git remotes; --reviews still needs gh)" >&2
  echo "  3) Both" >&2
  echo "  4) Skip reviews for now" >&2
  echo >&2

  while true; do
    reviews_prompt "Choose 1-4: " || {
      reviews_step_fail "Setup choice" \
        "Could not read your choice (no interactive terminal?)." \
        "" \
        "Run git-recap --reviews from a real terminal, or set up manually:
  brew install gh && gh auth login"
      return 1
    }
    choice="$(printf '%s' "$REPLY_LINE" | tr -d '[:space:]')"
    case "$choice" in
      1|2|3|4) break ;;
      *)
        reviews_step_fail "Setup choice" \
          "Invalid selection '${REPLY_LINE}'." \
          "" \
          "Enter 1, 2, 3, or 4."
        ;;
    esac
  done

  case "$choice" in
    4)
      reviews_step_fail "Reviews setup" \
        "You chose to skip setup." \
        "" \
        "When ready: git-recap --reviews --today"
      return 1
      ;;
  esac

  reviews_setup_python || return 1

  case "$choice" in
    1)
      reviews_setup_gh || return 1
      ;;
    2)
      reviews_setup_ssh || true
      echo >&2
      echo "    SSH alone cannot fetch PR reviews." >&2
      if reviews_confirm "    Set up GitHub CLI now so --reviews works? [Y/n] " y; then
        reviews_setup_gh || return 1
      else
        reviews_step_fail "GitHub CLI required" \
          "SSH may be configured, but --reviews still needs an authenticated gh session." \
          "" \
          "Run: brew install gh && gh auth login
Then: git-recap --reviews --today"
        return 1
      fi
      ;;
    3)
      reviews_setup_gh || return 1
      reviews_setup_ssh || true
      ;;
  esac

  echo >&2
  echo "==> Setup summary" >&2
  if reviews_python_ok; then reviews_step_ok "python3"; else echo "    ERROR: python3 still missing" >&2; fi
  if reviews_gh_installed && reviews_gh_authenticated && reviews_gh_api_ok; then
    reviews_step_ok "gh auth/API ($(gh api user --jq .login 2>/dev/null))"
    gh_ok=1
  else
    reviews_step_fail "GitHub CLI readiness" \
      "gh install/login/API checks did not all pass." \
      "$(reviews_gh_auth_detail)"$'\n'"$(reviews_gh_api_detail)" \
      "Fix with:
  gh auth status
  gh auth login
  gh api user --jq .login
Then re-run: git-recap --reviews --today"
    gh_ok=0
  fi
  if reviews_ssh_github_ok; then
    reviews_step_ok "SSH → GitHub"
  else
    echo "    Note: SSH → GitHub not verified (optional for --reviews)." >&2
  fi

  if [[ "$gh_ok" -eq 1 ]]; then
    echo "    Ready for --reviews." >&2
    return 0
  fi
  return 1
}

reviews_ensure_ready() {
  # Returns 0 when gh+python can fetch reviews.
  if reviews_python_ok && reviews_gh_installed && reviews_gh_authenticated && reviews_gh_api_ok; then
    return 0
  fi

  if ! reviews_is_tty; then
    if ! reviews_gh_installed; then
      reviews_setup_help "gh not installed (non-interactive)"
    elif ! reviews_gh_authenticated; then
      reviews_setup_help "gh not authenticated (non-interactive)"
    elif ! reviews_python_ok; then
      reviews_setup_help "python3 not installed (non-interactive)"
    else
      reviews_setup_help "GitHub API not reachable (non-interactive)"
    fi
    return 1
  fi

  echo "warning: --reviews needs a quick setup first." >&2
  reviews_setup_wizard
}

# Fetch GitHub PR reviews for the authenticated gh user into the Reviews bucket.
fetch_github_reviews() {
  local from_iso to_iso from_day login payload

  reviews_ensure_ready || return 1

  from_iso="$(approxidate_to_iso "$SINCE" 2>/dev/null || true)"
  if [[ -z "$from_iso" ]]; then
    reviews_step_fail "Parse --since" \
      "Could not turn '${SINCE}' into a timestamp for the GitHub query." \
      "" \
      "Use a preset or simple relative date:
  git-recap --reviews --today
  git-recap --reviews --since \"3 days ago\""
    return 1
  fi
  if [[ -n "$UNTIL" ]]; then
    to_iso="$(approxidate_to_iso "$UNTIL" 2>/dev/null || true)"
    if [[ -z "$to_iso" ]]; then
      reviews_step_fail "Parse --until" \
        "Could not turn '${UNTIL}' into a timestamp for the GitHub query." \
        "" \
        "Try an ISO date (YYYY-MM-DD) or \"yesterday\"."
      return 1
    fi
  else
    to_iso="$(python3 -c 'from datetime import datetime,timezone; print(datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"))')"
  fi

  if [[ "$ALL_AUTHORS" -eq 1 || -n "$AUTHOR_OVERRIDE" ]]; then
    echo "note: --reviews always uses the authenticated gh user (author filters apply to commits only)" >&2
  fi

  login="$(gh api user --jq .login 2>/dev/null || true)"
  if [[ -z "$login" ]]; then
    reviews_step_fail "Resolve GitHub user" \
      "gh could not return your login after setup." \
      "$(reviews_gh_api_detail)" \
      "Run: gh auth status && gh api user --jq .login
Then: git-recap --reviews --today"
    return 1
  fi

  from_day="$(printf '%s' "$from_iso" | cut -c1-10)"
  payload="$(
    gh api graphql -f query="
      query {
        search(query: \"type:pr reviewed-by:${login} updated:>=${from_day}\", type: ISSUE, first: 50) {
          nodes {
            ... on PullRequest {
              number
              title
              repository { name nameWithOwner }
              reviews(first: 40) {
                nodes { author { login } state submittedAt }
              }
            }
          }
        }
      }" 2>/dev/null || true
  )"

  if [[ -z "$payload" ]]; then
    if reviews_is_tty; then
      reviews_step_fail "Query GitHub for PR reviews" \
        "The GraphQL search returned no payload (auth, scopes, or network)." \
        "$(gh api user 2>&1 || true)" \
        "Re-authenticate and retry the query."
      if reviews_confirm "    Re-run gh auth login and retry? [Y/n] " y; then
        reviews_setup_gh || return 1
        login="$(gh api user --jq .login 2>/dev/null || true)"
        payload="$(
          gh api graphql -f query="
            query {
              search(query: \"type:pr reviewed-by:${login} updated:>=${from_day}\", type: ISSUE, first: 50) {
                nodes {
                  ... on PullRequest {
                    number
                    title
                    repository { name nameWithOwner }
                    reviews(first: 40) {
                      nodes { author { login } state submittedAt }
                    }
                  }
                }
              }
            }" 2>/dev/null || true
        )"
      fi
    fi
    if [[ -z "$payload" ]]; then
      reviews_step_fail "Query GitHub for PR reviews" \
        "Still could not load PR reviews from GitHub." \
        "$(gh api graphql -f query='query { viewer { login } }' 2>&1 || true)" \
        "Check network / SSO authorization for orgs, then:
  gh auth refresh -h github.com -s repo
  gh api user --jq .login
Commit recap will continue without reviews."
      return 1
    fi
  fi

  # Filter by review submittedAt (search only constrains PR updatedAt).
  while IFS=$'\t' read -r nwo repo number title state || [[ -n "${nwo:-}" ]]; do
    [[ -z "${nwo:-}" ]] && continue
    verb="$(review_verb_for_state "$state")"
    subject="$(shorten_subject "${verb} #${number}: ${title}")"
    [[ -z "$repo" ]] && repo="$nwo"
    record_github_review "$repo" "$subject" "PR#${number}"
    nwo=''
    repo=''
    number=''
    title=''
    state=''
  done < <(
    FROM_ISO="$from_iso" TO_ISO="$to_iso" LOGIN="$login" python3 -c '
import json, os, sys
from datetime import datetime

def parse(ts):
    return datetime.fromisoformat(ts.replace("Z", "+00:00"))

payload = json.load(sys.stdin)
login = os.environ["LOGIN"]
start = parse(os.environ["FROM_ISO"])
end = parse(os.environ["TO_ISO"])
nodes = (((payload.get("data") or {}).get("search") or {}).get("nodes")) or []
for pr in nodes:
    if not pr:
        continue
    repo = (pr.get("repository") or {})
    nwo = repo.get("nameWithOwner") or ""
    name = repo.get("name") or nwo
    number = pr.get("number")
    title = (pr.get("title") or "").replace("\t", " ").replace("\n", " ")
    for review in ((pr.get("reviews") or {}).get("nodes") or []):
        author = (review.get("author") or {}).get("login")
        if author != login:
            continue
        submitted = review.get("submittedAt")
        if not submitted:
            continue
        ts = parse(submitted)
        if ts < start or ts > end:
            continue
        state = review.get("state") or "COMMENTED"
        print(f"{nwo}\t{name}\t{number}\t{title}\t{state}")
' <<< "$payload"
  )

  return 0
}

# ---------------------------------------------------------------------------
# Resolve target list (Cases A / B / C)
# ---------------------------------------------------------------------------
REPOS=()
REQUIRE_GIT_DIR=0

# Canonical absolute path for deduplication (Bash 3.2-safe).
canonical_path() {
  local path="$1"
  if [[ -d "$path" ]]; then
    (cd "$path" && pwd)
  else
    printf '%s' "$path"
  fi
}

repo_already_queued() {
  local candidate="$1" existing
  for existing in "${REPOS[@]+"${REPOS[@]}"}"; do
    [[ "$existing" == "$candidate" ]] && return 0
  done
  return 1
}

queue_repo() {
  local path="$1" canon
  canon="$(canonical_path "$path")" || return 1
  if repo_already_queued "$canon"; then
    return 0
  fi
  REPOS+=("$canon")
}

collect_scan() {
  local parent="$1"
  if [[ "$RECURSIVE" -eq 1 ]]; then
    scan_subdirs_recursive "$parent"
  else
    scan_subdirs "$parent"
  fi
}

if [[ ${#TARGETS[@]} -gt 0 ]]; then
  REQUIRE_GIT_DIR=1
  for target in "${TARGETS[@]}"; do
    if [[ ! -d "$target" ]]; then
      echo "warning: skipping '${target}' (not a directory)" >&2
      continue
    fi
    if has_git_dir "$target"; then
      queue_repo "$target"
    elif [[ "$RECURSIVE" -eq 1 ]]; then
      while IFS= read -r -d '' entry; do
        queue_repo "$entry"
      done < <(collect_scan "$target")
    else
      echo "warning: skipping '$(basename "$target")' (not a Git repository; try --recursive)" >&2
    fi
  done
elif inside_git_repo "."; then
  queue_repo "."
else
  REQUIRE_GIT_DIR=1
  while IFS= read -r -d '' entry; do
    queue_repo "$entry"
  done < <(collect_scan ".")
fi

if [[ ${#REPOS[@]} -eq 0 ]]; then
  if [[ "$INCLUDE_REVIEWS" -eq 1 ]]; then
    : # allow review-only recap when no local repos were found
  elif [[ "$JSON" -eq 1 ]]; then
    TOTAL_COMMITS=0
    PRINTED_REPOS=0
    print_json
    exit 0
  else
    echo "No Git repositories found to recap." >&2
    exit 0
  fi
fi

# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------
printed=0
for repo in "${REPOS[@]+"${REPOS[@]}"}"; do
  if recap_repo "$repo" "$REQUIRE_GIT_DIR"; then
    printed=1
  fi
done

if [[ "$INCLUDE_REVIEWS" -eq 1 ]]; then
  fetch_github_reviews || true
  if [[ "$TOTAL_REVIEWS" -gt 0 ]]; then
    printed=1
  fi
fi

if [[ "$JSON" -eq 1 ]]; then
  print_json
elif [[ "$printed" -eq 0 ]]; then
  if [[ ${#REPOS[@]} -eq 0 && "$INCLUDE_REVIEWS" -eq 1 ]]; then
    echo "No Git repositories found, and no PR reviews in this timeframe." >&2
  else
    printf '%sNo commits by %s%s%s %s%s.\n' "$DIM" "$BOLD" "$DISPLAY_AUTHOR" "$RESET$DIM" "$(timeframe_label)" "$RESET"
  fi
elif [[ "$FLAT" -eq 1 ]]; then
  if [[ "$TOTAL_REVIEWS" -gt 0 ]]; then
    print_reviews_section
  fi
else
  print_standup_summary
fi

if [[ "$JSON" -eq 0 ]]; then
  printf '\n'
fi
